# =============================================================================
# IP-Pulse environment (copy to .env and fill in)
# =============================================================================
# Graceful-degradation switch: when true, any tool whose live creds are missing
# or whose live call fails will return typed mock data instead of throwing.
# Keep true for local dev and demo-day safety.
MOCK_FALLBACK=true

# -----------------------------------------------------------------------------
# TIER 1 — required for the web chat demo to work at all
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# TIER 1 — required for the Slack and Vapi demo surfaces (web chat works without)
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# TIER 2 — upgrade MCP tools from mocks to real data (each is optional)
# -----------------------------------------------------------------------------
USPTO_API_KEY=
GITHUB_TOKEN=
TINYFISH_API_KEY=
TINYFISH_BASE_URL=https://api.tinyfish.io

# Akash ML (Kimi K2.6) — OpenAI-compatible endpoint
AKASHML_API_KEY=
AKASHML_BASE_URL=https://api.akashml.com/v1
AKASHML_MODEL=kimi-k2.6

# Ghost AI DB (https://ghost.build) — agent-native Postgres on Timescale Cloud.
# Run `ghost create --name ip-pulse --wait && ghost connect ip-pulse` and paste
# the resulting URL here. Do NOT append ?sslmode=require — pg v8.13+ treats
# that as verify-full and rejects Ghost's managed CA chain. The integration
# enables TLS via explicit pool config. See deploy/ghost/README.md.
GHOST_DATABASE_URL=

# Nexla (reads from the sink your Nexla flow writes to)
NEXLA_SINK_URL=

# -----------------------------------------------------------------------------
# TIER 3 — gated / deferred
# -----------------------------------------------------------------------------
# PACER requires paid creds. CourtListener is a free alternative covering most
# federal dockets; leave both blank to keep the tool in mock mode.
PACER_USERNAME=
PACER_PASSWORD=
COURTLISTENER_TOKEN=

# WunderGraph (self-hosted via docker compose; override if pointing elsewhere)
WUNDERGRAPH_URL=http://localhost:9991
WUNDERGRAPH_API_KEY=
