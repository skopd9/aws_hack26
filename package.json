{
  "name": "ip-pulse",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time agentic patent-intelligence platform. Closes the Latency Gap and Interpretation Gap in IP defense for software engineers.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "worker": "tsx workers/index.ts",
    "wg:generate": "wunderctl generate",
    "wg:up": "wunderctl up",
    "ghost:migrate": "ghost sql ip-pulse < deploy/ghost/schema.sql",
    "security:scan": "bash scripts/security-scan.sh"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai-compatible": "^0.1.0",
    "@ai-sdk/react": "^1.0.0",
    "ai": "^4.0.0",
    "ioredis": "^5.4.1",
    "next": "^14.2.33",
    "pg": "^8.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.33",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
