{
  "name": "ip-pulse",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time agentic patent-intelligence platform. Closes the Latency Gap and Interpretation Gap in IP defense for software engineers.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "worker": "tsx workers/index.ts",
    "subgraphs:dev": "tsx --conditions=react-server subgraphs/index.ts",
    "subgraphs:start": "node --conditions=react-server --import tsx subgraphs/index.ts",
    "cosmo:setup": "bash cosmo/setup.sh",
    "cosmo:check": "for s in patents priorart litigation verification analysis; do wgc subgraph check $s --namespace development --schema cosmo/schemas/$s.graphqls; done",
    "ghost:migrate": "ghost sql ip-pulse < deploy/ghost/schema.sql",
    "security:scan": "bash scripts/security-scan.sh",
    "akash:deploy": "tsx scripts/akash-deploy.ts",
    "akash:status": "tsx scripts/akash-status.ts",
    "akash:update": "tsx scripts/akash-update.ts",
    "smoke:tool-errors": "tsx --conditions=react-server scripts/smoke-tool-errors.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai-compatible": "^0.1.0",
    "@ai-sdk/react": "^1.0.0",
    "@apollo/subgraph": "^2.13.3",
    "@vapi-ai/web": "^2.5.2",
    "ai": "^4.0.0",
    "concurrently": "^9.2.1",
    "graphql": "^16.13.2",
    "graphql-tag": "^2.12.6",
    "graphql-yoga": "^5.21.0",
    "ioredis": "^5.4.1",
    "next": "^14.2.33",
    "pg": "^8.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.33",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
